print(na_summary)
cat("Nota: La presenza di NA nei log di sicurezza rappresenta una mancata segnalazione strutturale.\n\n")
# 2. Analisi Esplorativa (EDA) e Distribuzioni
cat("--- FASE 1.2: STATISTICHE DESCRITTIVE (REALI) ---\n")
print(summary(df_real[, .(`Packet Length`, `Anomaly Scores`)]))
# Istogramma per Packet Length (Multimodale)
ggplot(df_real, aes(x = `Packet Length`)) +
geom_histogram(bins = 50, fill = "steelblue", color = "white", alpha = 0.7) +
labs(title = "Distribuzione Multimodale di Packet Length (Dati Reali)",
x = "Packet Length (Bytes)", y = "Frequenza") +
theme_minimal()
# Boxplot per Anomaly Scores (Uniforme, senza Outlier)
ggplot(df_real, aes(y = `Anomaly Scores`)) +
geom_boxplot(fill = "coral", alpha = 0.7) +
labs(title = "Boxplot di Anomaly Scores (Dati Reali)", y = "Punteggio") +
theme_minimal()
# 3. Verifica d'Ipotesi (Test del Chi-Quadrato)
cat("\n--- FASE 1.3: TEST CHI-QUADRATO (INDIPENDENZA) ---\n")
tab_contingenza <- table(df_real$Protocol, df_real$`Action Taken`)
test_chi2 <- chisq.test(tab_contingenza)
print(test_chi2)
# 4. Modellazione Avanzata: Clustering K-Means
cat("\n--- FASE 1.4: CLUSTERING K-MEANS ---\n")
df_cluster <- na.omit(df_real[, .(`Packet Length`, `Anomaly Scores`)])
df_scaled <- scale(df_cluster)
set.seed(123)
kmeans_res <- kmeans(df_scaled, centers = 2, nstart = 25)
df_cluster[, Cluster := as.factor(kmeans_res$cluster)]
cat("\nCentroidi dei Cluster (Medie):\n")
print(df_cluster[, .(Media_Packet = mean(`Packet Length`), Media_Anomaly = mean(`Anomaly Scores`)), by = Cluster])
# OB2 - GENERAZIONE SINTETICA E ANALISI COMPARATIVA
cat("\n--- FASE 2.1: CARICAMENTO DATASET SINTETICO ---\n")
# 1. Carico separando per virgola
df_synth <- fread("cybersecurity_sintetico.csv", sep = ",", dec = ".", strip = TRUE)
# 2. Pulizia e conversione manuale dei decimali con la virgola (es. "84,12" -> 84.12)
df_synth[, `Anomaly Scores` := as.numeric(gsub(",", ".", as.character(`Anomaly Scores`)))]
df_synth[, `Packet Length` := as.numeric(gsub(",", ".", as.character(`Packet Length`)))]
# 3. Allineamento del Timestamp
df_synth[, Timestamp := as.POSIXct(as.character(Timestamp), format = "%Y-%m-%d %H:%M:%S")]
# 4. CONFRONTO DELLE STATISTICHE DESCRITTIVE
cat("\n==================================================\n")
cat("--- CONFRONTO STATISTICO: ANOMALY SCORES ---\n")
cat("\n[DATI REALI]:\n")
print(summary(df_real$`Anomaly Scores`))
cat("Deviazione Standard Reale:", sd(df_real$`Anomaly Scores`, na.rm = TRUE), "\n")
cat("\n[DATI SINTETICI]:\n")
print(summary(df_synth$`Anomaly Scores`))
cat("Deviazione Standard Sintetica:", sd(df_synth$`Anomaly Scores`, na.rm = TRUE), "\n")
cat("\n==================================================\n")
cat("--- CONFRONTO STATISTICO: PACKET LENGTH ---\n")
cat("\n[DATI REALI]:\n")
print(summary(df_real$`Packet Length`))
cat("Deviazione Standard Reale:", sd(df_real$`Packet Length`, na.rm = TRUE), "\n")
cat("\n[DATI SINTETICI]:\n")
print(summary(df_synth$`Packet Length`))
cat("Deviazione Standard Sintetica:", sd(df_synth$`Packet Length`, na.rm = TRUE), "\n")
# 5. VISUALIZZAZIONE COMPARATIVA (BOXPLOT DI CONFRONTO)
df_real_subset <- data.table(Score = df_real$`Anomaly Scores`, Tipo = "Reale")
df_synth_subset <- data.table(Score = df_synth$`Anomaly Scores`, Tipo = "Sintetico")
df_confronto <- rbind(df_real_subset, df_synth_subset)
ggplot(df_confronto, aes(x = Tipo, y = Score, fill = Tipo)) +
geom_boxplot(alpha = 0.7) +
labs(
title = "Confronto delle Distribuzioni degli Anomaly Scores",
x = "Tipologia di Dataset",
y = "Punteggio di Anomalia"
) +
theme_minimal() +
scale_fill_manual(values = c("steelblue", "coral"))
cat("\n==================================================\n")
cat("Analisi completata con successo!\n")
cat("\nPipeline completata con successo!\n")
